<Window x:Class="NovelMoyo.Views.BookshelfWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="书架"
        Width="450" Height="400"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListView Grid.Row="0" x:Name="NovelList"
                  ItemsSource="{Binding Novels}"
                  SelectedItem="{Binding SelectedNovel}"
                  MouseDoubleClick="NovelList_MouseDoubleClick"
                  KeyDown="NovelList_KeyDown">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="书名" Width="180" DisplayMemberBinding="{Binding Title}" />
                    <GridViewColumn Header="格式" Width="50" DisplayMemberBinding="{Binding Format}" />
                    <GridViewColumn Header="进度" Width="100" DisplayMemberBinding="{Binding ProgressText}" />
                    <GridViewColumn Header="最后阅读" Width="130" DisplayMemberBinding="{Binding LastReadAt, StringFormat=yyyy-MM-dd HH:mm}" />
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="导入" Command="{Binding ImportFileCommand}" Width="80" Margin="0,0,8,0" />
            <Button Content="移除" Command="{Binding RemoveNovelCommand}" Width="80" Margin="0,0,8,0" />
            <Button Content="打开" Command="{Binding OpenNovelCommand}" Width="80" Margin="0,0,8,0" IsDefault="True" />
            <Button Content="关闭" Width="80" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
