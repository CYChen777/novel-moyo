<Window x:Class="NovelMoyo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NovelMoyo.Views.Controls"
        Title="NovelMoyo"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        Height="400" Width="500">

    <Border x:Name="FrameBorder"
            Background="{DynamicResource BackgroundBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            CornerRadius="4">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Reading area -->
            <ScrollViewer Grid.Row="0"
                          x:Name="ReadingScrollViewer"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          ScrollChanged="ReadingScrollViewer_ScrollChanged">
                <TextBlock x:Name="ReadingText"
                           Text="拖拽 .txt 或 .epub 文件到此处开始阅读"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}"
                           FontFamily="{DynamicResource ReadingFontFamily}"
                           FontSize="16"
                           LineHeight="28"
                           Padding="8,4" />
            </ScrollViewer>

            <!-- Floating toast overlay for speed/passthrough feedback -->
            <Border x:Name="ToastOverlay"
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="#CC000000"
                    CornerRadius="4"
                    Padding="12,6"
                    Margin="0,8,0,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="ToastText"
                           FontSize="12"
                           Foreground="White"
                           HorizontalAlignment="Center" />
            </Border>

            <!-- Passthrough mode indicator -->
            <Border x:Name="PassthroughIndicator"
                    Grid.Row="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="#99FF6600"
                    CornerRadius="3"
                    Padding="6,3"
                    Margin="0,8,8,0"
                    Visibility="Collapsed">
                <TextBlock Text="穿透模式"
                           FontSize="10"
                           Foreground="White"
                           FontWeight="SemiBold" />
            </Border>

            <!-- Status bar using ReadingStatusBar control -->
            <controls:ReadingStatusBar x:Name="StatusBar"
                                       Grid.Row="1"
                                       ChapterTitle="{Binding ChapterTitle}"
                                       ChapterInfo="{Binding ChapterDisplay}"
                                       Background="{DynamicResource StatusBarBrush}"
                                       Margin="0,4,0,0" />
        </Grid>
    </Border>
</Window>
