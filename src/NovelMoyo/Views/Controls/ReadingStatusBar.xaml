<UserControl x:Class="NovelMoyo.Views.Controls.ReadingStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="ChapterTitleText"
                   Grid.Column="0"
                   Text="{Binding ChapterTitle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Margin="6,4"
                   FontSize="11"
                   Foreground="{DynamicResource StatusBarTextBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />

        <TextBlock x:Name="ChapterInfoText"
                   Grid.Column="1"
                   Text="{Binding ChapterInfo, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Margin="6,4"
                   FontSize="11"
                   Foreground="{DynamicResource StatusBarTextBrush}"
                   VerticalAlignment="Center" />
    </Grid>
</UserControl>
