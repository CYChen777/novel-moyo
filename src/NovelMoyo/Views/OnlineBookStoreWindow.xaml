<Window x:Class="NovelMoyo.Views.OnlineBookStoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="在线书城"
        Width="700" Height="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search Area -->
        <GroupBox Grid.Row="0" Header="搜索" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SearchBox"
                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="SearchBox_KeyDown" />
                <Button Grid.Column="1" Content="搜索" Command="{Binding SearchCommand}"
                        Width="70" Margin="8,0,0,0" />
            </Grid>
        </GroupBox>

        <!-- URL Input Area -->
        <GroupBox Grid.Row="1" Header="URL粘贴" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="UrlBox"
                         Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="UrlBox_KeyDown" />
                <Button Grid.Column="1" Content="解析" Command="{Binding SearchByUrlCommand}"
                        Width="70" Margin="8,0,0,0" />
            </Grid>
        </GroupBox>

        <!-- Search Results + Download Button -->
        <GroupBox Grid.Row="2" Header="搜索结果" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListView Grid.Row="0" x:Name="ResultsList"
                          ItemsSource="{Binding SearchResults}"
                          SelectedItem="{Binding SelectedResult}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="书名" Width="180" DisplayMemberBinding="{Binding Title}" />
                            <GridViewColumn Header="作者" Width="100" DisplayMemberBinding="{Binding Author}" />
                            <GridViewColumn Header="章节数" Width="70" DisplayMemberBinding="{Binding TotalChapters, TargetNullValue='--'}" />
                            <GridViewColumn Header="来源" Width="100" DisplayMemberBinding="{Binding SourceName}" />
                            <GridViewColumn Header="最新章节" Width="150" DisplayMemberBinding="{Binding LatestChapter}" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Download Controls -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="下载到：" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding DownloadPath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="4,0,4,0" />
                        <Button Grid.Column="2" Content="浏览..." Command="{Binding BrowsePathCommand}"
                                Width="60" />
                    </Grid>
                    <Button Content="开始下载" Command="{Binding StartDownloadCommand}"
                            Width="120" Height="30" HorizontalAlignment="Right"
                            FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Download Tasks -->
        <GroupBox Grid.Row="3" Header="下载任务" Margin="0,0,0,8">
            <ListView ItemsSource="{Binding DownloadTasks}" MaxHeight="150"
                      SelectedItem="{Binding ActiveDownload}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="书名" Width="150" DisplayMemberBinding="{Binding Title}" />
                        <GridViewColumn Header="状态" Width="100" DisplayMemberBinding="{Binding StatusText}" />
                        <GridViewColumn Header="进度" Width="90" DisplayMemberBinding="{Binding ProgressText}" />
                        <GridViewColumn Header="进度条" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ProgressBar Width="60" Height="16"
                                                 Minimum="0"
                                                 Maximum="{Binding TotalChapters}"
                                                 Value="{Binding CompletedChapters}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="操作" Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="取消" Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4">
            <TextBlock Text="{Binding StatusMessage}" />
        </StatusBar>
    </Grid>
</Window>
