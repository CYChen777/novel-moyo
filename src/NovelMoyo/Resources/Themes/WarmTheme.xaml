<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="BackgroundBrush" Color="#CC332200" />
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#664400" />
    <SolidColorBrush x:Key="TextBrush" Color="#FFEECC" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#BBAA88" />
    <SolidColorBrush x:Key="StatusBarBrush" Color="#443300" />
    <SolidColorBrush x:Key="StatusBarTextBrush" Color="#DDCC99" />
    <SolidColorBrush x:Key="BorderBrush" Color="#664400" />

    <FontFamily x:Key="ReadingFontFamily">Microsoft YaHei, SimSun, Segoe UI</FontFamily>
    <sys:Double x:Key="ReadingFontSize">16</sys:Double>
    <sys:Double x:Key="ReadingLineHeight">28</sys:Double>

</ResourceDictionary>
