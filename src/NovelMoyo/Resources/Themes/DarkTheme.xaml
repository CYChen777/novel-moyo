<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="BackgroundBrush" Color="#CC000000" />
    <SolidColorBrush x:Key="WindowBorderBrush" Color="#555555" />
    <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextDimBrush" Color="#AAAAAA" />
    <SolidColorBrush x:Key="StatusBarBrush" Color="#333333" />
    <SolidColorBrush x:Key="StatusBarTextBrush" Color="#CCCCCC" />
    <SolidColorBrush x:Key="BorderBrush" Color="#555555" />

    <FontFamily x:Key="ReadingFontFamily">Microsoft YaHei, SimSun, Segoe UI</FontFamily>
    <sys:Double x:Key="ReadingFontSize">16</sys:Double>
    <sys:Double x:Key="ReadingLineHeight">28</sys:Double>

</ResourceDictionary>
